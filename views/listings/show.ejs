  </a>

  <div class="row g-4 mt-2 align-items-start">

    <!-- LEFT -->
    <div class="col-lg-8">

      <!-- IMAGE -->
      <!-- IMAGE GALLERY -->

<div class="gallery-wrapper">

  <!-- MAIN IMAGE -->
  <div class="gallery-main">

    <img
      src="<%= listing.image?.url %>"
      class="gallery-main-img"
    >

    <div class="top-badge">
      ⭐ Top Rated
    </div>

    <div class="photo-count">
      <i class="fa-solid fa-camera"></i>
      24 Photos
    </div>

  </div>

  <!-- SMALL IMAGES -->

  <div class="gallery-grid">

    <img src="<%= listing.image?.url %>">

    <img src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85">

    <img src="https://images.unsplash.com/photo-1522708323590-d24dbb6b0267">

    <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945">

    <img src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85">

  </div>

</div>

      <!-- TITLE -->
      <div class="mt-4">

        <h1 class="listing-main-title">
          <%= listing.title %>
        </h1>

        <p class="listing-location">
          <i class="fa-solid fa-location-dot"></i>
          <%= listing.location %>, <%= listing.country %>
        </p>

      </div>

      <!-- HOST -->
      <!-- HOST PREMIUM -->

<div class="premium-host-box">

  <div class="host-profile">

    <img
      src="https://i.pravatar.cc/100"
      class="host-profile-img"
    >

    <div>

      <h4>
        Hosted by <%= listing.owner.username %>
      </h4>

      <p>
        Superhost · 25 listings
      </p>

    </div>

  </div>

  <div class="host-stats">

    <div class="stat-item">
      ⭐ 4.8
      <span>126 reviews</span>
    </div>

    <div class="stat-item">
      🛡 Verified
      <span>Identity verified</span>
    </div>

  </div>

</div>

<% if(currUser && listing.owner._id.equals(currUser._id)){ %>

<div class="d-flex gap-2 mt-3">

  <a
    href="/listings/<%= listing._id %>/edit"
    class="btn btn-dark"
  >
    Edit
  </a>

  <form
    method="POST"
    action="/listings/<%= listing._id %>?_method=DELETE"
  >

    <button
      class="btn btn-danger"
    >
      Delete
    </button>

  </form>

</div>

<% } %>

      <!-- DESCRIPTION -->
      <div class="description-section">

        <h4>About this place</h4>

        <p>
          <%= listing.description %>
        </p>

      </div>

      <!-- PROPERTY FEATURES -->

<div class="feature-pills">

  <div class="feature-pill">
    👥 4 Guests
  </div>

  <div class="feature-pill">
    🛏 2 Bedrooms
  </div>

  <div class="feature-pill">
    🚿 2 Bathrooms
  </div>

  <div class="feature-pill">
    🛌 2 Beds
  </div>

</div>

<!-- WEATHER SECTION -->

<div class="weather-box mt-4">

  <div class="weather-header">

    <h4>
      Current Weather
    </h4>

    <span class="live-badge">
      LIVE
    </span>

  </div>

  <div id="weatherCard">

    <% if(weatherData){ %>

<div class="weather-card-inner">

  <div class="weather-left">

    <img
      src="https://openweathermap.org/img/wn/<%= weatherData.icon %>@2x.png"
      class="weather-icon"
    >

    <div>

      <h2>
        <%= weatherData.temp %>°C
      </h2>

      <p>
        <%= weatherData.condition %>
      </p>

    </div>

  </div>

  <div class="weather-stats">

    <div class="weather-stat">

      <span>
        Feels Like
      </span>

      <strong>
        <%= weatherData.feels %>°C
      </strong>

    </div>

    <div class="weather-stat">

      <span>
        Humidity
      </span>

      <strong>
        <%= weatherData.humidity %>%
      </strong>

    </div>

    <div class="weather-stat">

      <span>
        Wind
      </span>

      <strong>
        <%= weatherData.wind %> km/h
      </strong>

    </div>

  </div>

</div>

<% } else { %>

<p>
  Weather unavailable
</p>

<% } %>

    <div class="weather-loading">

      Loading weather...

    </div>

  </div>

</div>

<h3>Location</h3>

<div id="map"></div>

<style>
#map{
  height: 400px;
  width: 100%;
  border-radius: 15px;
}
</style>

<script>

const geometry =
<%- JSON.stringify(listing.geometry || null) %>;

console.log(geometry);

if(
  geometry &&
  geometry.coordinates &&
  geometry.coordinates.length === 2
){

  const lng =
  geometry.coordinates[0];

  const lat =
  geometry.coordinates[1];

  const map =
  L.map('map').setView([lat, lng], 13);

  L.tileLayer(
    'https://tile.openstreetmap.org/{z}/{x}/{y}.png',
    {
      attribution:
      '&copy; OpenStreetMap contributors'
    }
  ).addTo(map);

  L.marker([lat, lng])
    .addTo(map)
    .bindPopup("<%= listing.title %>")
    .openPopup();

}
else{

  document.getElementById("map").innerHTML =
  "<h4>Location not available</h4>";

}

</script>



      <!-- REVIEWS -->
    <!-- =========================
     PREMIUM REVIEWS
========================= -->

<div class="premium-review-section">

  <!-- TOP -->

  <div class="review-heading-box">

    <div>

      <h2>
        ⭐ 4.8 · Guest Reviews
      </h2>

      <p>
        Real reviews from real Wanderlust guests
      </p>

    </div>

    <% if(currUser){ %>

    <button
      class="write-review-btn"
      data-bs-toggle="modal"
      data-bs-target="#reviewModal"
    >
      ✍ Write a Review
    </button>

    <% } %>

  </div>

  <!-- REVIEW GRID -->

  <div class="row g-4 mt-2">

    <% for(review of listing.reviews){ %>

    <div class="col-lg-6">

      <div class="premium-review-card">

        <!-- TOP -->

        <div class="review-top-area">

          <div class="review-user-info">

            <img
              src="https://i.pravatar.cc/150?u=<%= review.author.username %>"
              class="review-avatar"
            >

            <div>

              <h5>
                <%= review.author.username %>
              </h5>

              <p>
                Wanderlust Guest
              </p>

            </div>

          </div>

          <div class="review-score">
            ⭐ <%= review.rating %>.0
          </div>

        </div>

        <!-- COMMENT -->

        <div class="review-text">

          <p>
            <%= review.comment %>
          </p>

        </div>

        <!-- FOOTER -->

        <div class="review-bottom">

          <span>
            Stayed Recently
          </span>

          <% if(currUser && review.author._id.equals(currUser._id)){ %>

          <form
            method="POST"
            action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
          >

            <button class="delete-review-modern">
              Delete
            </button>

          </form>

          <% } %>

        </div>

      </div>

    </div>

    <% } %>

  </div>

</div>

<!-- =========================
     REVIEW MODAL
========================= -->

<div
  class="modal fade"
  id="reviewModal"
  tabindex="-1"
>

  <div class="modal-dialog modal-dialog-centered">

    <div class="modal-content review-modal-content">

      <form
        action="/listings/<%= listing.id %>/reviews"
        method="POST"
      >

        <div class="modal-header border-0">

          <h4 class="fw-bold">
            Write a Review
          </h4>

          <button
            type="button"
            class="btn-close"
            data-bs-dismiss="modal"
          ></button>

        </div>

        <div class="modal-body">

          <!-- RATING -->

          <label class="mb-2 fw-bold">
            Rating
          </label>

          <select
            name="review[rating]"
            class="form-select mb-4"
          >

            <option value="5">⭐⭐⭐⭐⭐ Excellent</option>
            <option value="4">⭐⭐⭐⭐ Very Good</option>
            <option value="3">⭐⭐⭐ Good</option>
            <option value="2">⭐⭐ Average</option>
            <option value="1">⭐ Poor</option>

          </select>

          <!-- COMMENT -->

          <textarea
            name="review[comment]"
            rows="5"
            class="form-control"
            placeholder="Share your experience..."
            required
          ></textarea>

        </div>

        <div class="modal-footer border-0">

          <button
            class="submit-review-btn"
          >
            Submit Review
          </button>

        </div>

      </form>

    </div>

  </div>

</div>

</div>


      <!-- MAP -->
       
      <!-- <div class="map-box mt-4">

        <h4 class="mb-3">
          Where you'll be
        </h4>

        <div id="map"></div>

      </div>

    </div> -->

 
    <!-- RIGHT SIDE -->
    <div class="col-lg-4 right-sticky">

      <!-- BOOKING CARD -->
      <div class="booking-box">

        <div class="booking-top">

          <h2>
            ₹ <%= listing.price.toLocaleString("en-IN") %>
            <span>/ night</span>
          </h2>

          <div class="rating-box">
            ⭐ 4.8
          </div>

        </div>

        <!-- DATES -->

        <div class="date-grid">

          <div class="date-input-box">
            <label>Check In</label>
            <input type="date" name="checkIn">
          </div>

          <div class="date-input-box">
            <label>Check Out</label>
            <input type="date" name="checkOut">
          </div>

        </div>

        <!-- GUEST -->
        <div class="guest-box mt-3">

          <label>Guests</label>

          <input
            type="text"
            value="2 guests"
          >

        </div>

        <!-- TOTAL -->
        <div class="mt-3">

          <label>Total Price</label>

          <input
            type="number"
            name="totalPrice"
            class="total-input"
            readonly
          >

        </div>

        <!-- BUTTONS -->

        <button
          class="reserve-main-btn mt-4"
          onclick="payNow()"
        >
          Reserve Now
