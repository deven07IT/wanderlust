<script>
  const whatsappBtn = document.getElementById("whatsappBtn");

  //  Default owner number (backup)
  let phone = "919876543210";

  //  Agar listing page pe hai to dynamic data lo
  <% if (typeof listing !== "undefined" && listing.owner && listing.owner.mobile) { %>
    phone = "<%= listing.owner.mobile.replace(/\D/g, '') %>";
  <% } %>

  const message = "Hi, I am interested in your listing";

  whatsappBtn.href = `https://api.whatsapp.com/send?phone=${phone}&text=${encodeURIComponent(message)}`;
</script>

