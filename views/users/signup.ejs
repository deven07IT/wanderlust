<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <h1 class="col-6 offset-3">SignUp on Wanderlust</h1>

  <div class="col-6 offset-3">
    <form action="/signup" method="POST" class="needs-validation" novalidate>

      <!-- USERNAME -->
      <div class="mb-3">
        <label class="form-label" for="username">Username</label>
        <input name="username" class="form-control" id="username" type="text" required>
        <div class="invalid-feedback">Looks good!</div>
      </div>

      <!-- EMAIL -->
      <div class="mb-3">
        <label class="form-label" for="email">Email</label>
        <input name="email" class="form-control" id="email" type="email" required>
      </div>

      <!-- 🔥 MOBILE NUMBER (ADD THIS) -->
      <div class="mb-3">
        <label class="form-label" for="mobile">Mobile Number</label>
        <input 
          name="mobile" 
          class="form-control" 
          id="mobile" 
          type="text" 
          placeholder="Enter mobile (e.g. 919876543210)" 
          required
        >
      </div>

      <!-- PASSWORD -->
      <div class="mb-3">
        <label class="form-label" for="password">Password</label>
        <input name="password" class="form-control" id="password" type="password" required>
      </div>

      <button class="btn btn-success">SignUp</button>
    </form>
  </div>
</div>